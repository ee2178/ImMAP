{
    "task": "ipalm",

    "experiment": {
        "name": "LPDSNet_knee_recon_R6_meas"
    },

    "model": {
        "type": "IPALMNet",

        "params": {
            "adaptive": true,
            "K": 30,
            "M": 169,
            "C": 1,
            "P": 7,
            "s": 2,
            "sigma_hpf":0.2
        }
    },

    "paths": {
        "save_dir": "trained_nets/knee/LPDS_MRI_Recon_R6",
        "ckpt": null
    },

    "data": {
        "train": {
            "task": "recon",
            "anatomy": "knee",
            "batch_size": 1,
            "crop_size": null,
            "center_crop": null,
            "random_flips": false,
            "start_slice": 12,
            "end_slice": 25,
            "scale_fac": 5000.0,
            "kspace_root": "../datasets/fastmri/knee/multicoil_train",
            "smap_root": "../datasets/fastmri_preprocessed/knee_coil_combined/pd/train"
        },

        "val": {
            "task": "recon",
            "anatomy": "knee",
            "batch_size": 1,
            "crop_size": null,
            "center_crop": null,
            "random_flips": false,
            "start_slice": 12,
            "end_slice": 25,
            "scale_fac": 5000.0,
            "kspace_root": "../datasets/fastmri/knee/multicoil_val",
            "smap_root": "../datasets/fastmri_preprocessed/knee_coil_combined/pd/val"
        }
    },

    "training": {
        "max_steps": 300000,
        "noise_std": [0.01, 0.02],
        "noise_dist": "uniform",
        "loss_type": "magnitude-nl1-nl2",
        "clip_grad": 0.5,
        "log_every": 50,
        "val_every": 2000,
        "save_every": 5000,
        "use_organ_mask": false
    },

    "mri": {
        "R": 6,
        "acs_lines": 20,
        "mask_dist": "uniform",
        "kspace_type": "measurement",
        "whiten_kspace": true
    },

    "optimizer": {
        "type": "Adam",
        
        "params": {
            "lr": 0.0005
        }  
    },

    "scheduler": {
        "type": "CosineAnnealingLR",
        
        "params": {
            "eta_min": 1.0e-6,
            "T_max": 300000
        }
    },

    "wandb": {
        "project": "IPALMNet_E2E_R6"
    }
}
